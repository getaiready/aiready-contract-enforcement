    "ai-signal-clarity": {
      "checkMagicLiterals": true,
      "checkBooleanTraps": true,
      "checkAmbiguousNames": true,
      "checkUndocumentedExports": false,
      "checkImplicitSideEffects": true,
      "checkDeepCallbacks": true,
      "checkOverloadedSymbols": true,
      "checkLargeFiles": true,
      "excludePatterns": [
        "**/parsers/**",
        "**/icons/**",
        "**/*.config.*",
        "**/*.setup.*",
        "**/types.ts",
        "**/index.ts"
