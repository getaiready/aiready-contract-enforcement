    "agent-grounding": {
      "maxRecommendedDepth": 4,
      "readmeStaleDays": 90,
      "additionalVagueNames": ["stuff", "misc", "temp", "test"]
    },
    "testability-index": {
      "minCoverageRatio": 0.3,
      "testPatterns": ["**/*.test.ts", "**/__tests__/**", "**/*.spec.ts"],
      "maxDepth": 10
    },
    "doc-drift": {
      "maxCommits": 50,
      "staleMonths": 3,
      "ignorePrivateFunctions": true,
      "ignoreSingleLetterParams": true,
      "ignoreUtilityFunctions": true
    },
    "dependency-health": {
      "trainingCutoffYear": 2023
    },
    "change-amplification": {
      "ignoreBarrelFiles": true
    }
  },
  "visualizer": {
    "groupingDirs": ["packages", "src", "lib"],
    "graph": {
      "maxNodes": 5000,
      "maxEdges": 10000
    }
  }
