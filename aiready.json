{
  "$schema": "https://getaiready.dev/schema.json",
  "threshold": 80,
  "scan": {
    "include": [
      "src/**/*.ts",
      "src/**/*.js",
      "lib/**/*.ts",
      "packages/*/src/**/*.ts",
      "apps/**/*.ts",
      "apps/**/*.tsx"
    ],
    "tools": [
      "pattern-detect",
      "context-analyzer",
      "naming-consistency",
      "ai-signal-clarity",
      "agent-grounding",
      "testability-index",
      "doc-drift",
      "dependency-health",
      "change-amplification"
    ]
  },
  "output": {
    "format": "console",
    "showBreakdown": true,
    "saveTo": "aiready-report.json"
  },
  "scoring": {
    "profile": "balanced"
  },
  "tools": {
    "pattern-detect": {
      "minSimilarity": 0.4,
      "minLines": 5,
      "minSharedTokens": 8,
      "approx": true,
      "batchSize": 200,
      "maxCandidatesPerBlock": 500,
      "maxResults": 10,
      "minClusterFiles": 3,
      "minClusterTokenCost": 1000,
      "excludeFiles": [
        "**/provider.ts",
        "**/scoring.ts",
        "**/tsup.config.ts",
        "**/vitest.config.ts"
      ],
      "outputFormat": "console"
    },
    "context-analyzer": {
      "maxContextBudget": 50000,
      "minCohesion": 0.25,
      "maxDepth": 20,
      "maxFragmentation": 0.85,
      "focus": "all",
      "includeNodeModules": false
    },
    "naming-consistency": {
      "checkNaming": true,
      "checkPatterns": true,
      "checkArchitecture": true,
      "minSeverity": "warning",
      "shortWords": [
        "id",
        "db",
        "ui",
        "ai",
