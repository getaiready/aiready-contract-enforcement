{
  "name": "@aiready/skills",
  "version": "0.2.2",
  "private": true,
  "description": "AI-friendly coding practices for AI agents - procedural knowledge for writing maintainable code",
  "license": "MIT",
  "author": "AIReady",
  "repository": {
    "type": "git",
    "url": "https://github.com/getaiready/aiready-skills.git"
  },
  "homepage": "https://github.com/getaiready/aiready-skills",
  "bugs": {
    "url": "https://github.com/getaiready/aiready-skills/issues"
  },
  "keywords": [
    "aiready",
    "ai-coding",
    "best-practices",
    "code-quality",
    "agent-skills",
    "ai-friendly"
  ],
  "type": "module",
  "scripts": {
    "build": "tsx src/build.ts",
    "build:upgrade": "tsx src/build.ts --upgrade-version",
    "validate": "tsx src/validate.ts",
    "test": "vitest run",
    "dev": "pnpm run build && pnpm run validate",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "format-check": "prettier --check . --ignore-path ../../.prettierignore",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@aiready/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "files": [
    "aiready-best-practices/**/*",
    "README.md",
    "LICENSE"
  ]
}
